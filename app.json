{
  "expo": {
    "name": "Just Move",
    "slug": "frontend",
    "version": "1.2.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "supportsTablet": false,
      "bundleIdentifier": "com.justmovechess.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/iconandroid.png",
        "backgroundColor": "#000000"
      },
      "package": "com.justmove.app",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-apple-authentication",
      "react-native-iap",
      [
        "expo-build-properties",
      {
    "ios": {
      "useFrameworks": "static",
      "useModularHeaders": true
    },
    "android": {
      "kotlinVersion": "2.2.0"
    }
  }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.226445408215-38u7tbvl7dgtc9k01rp7f6bp6pqkcfb9"
        }
      ],
      "expo-web-browser",
      "expo-audio",
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "55003675-01c3-44ff-a9ad-b129c3df579f"
      }
    },
    "owner": "cyberglobers"
  }
}